	(text "# 🟡 BLK_SWITCHES - Opis funkcjonalny\n# ==================================\n# Sekcja: Przełączniki wejściowe panelu sterowania\n# Układ główny: MCP23017 (U11) @ I²C addr 0x21\n# Napięcie logiki: 3.3V\n# Filtracja: R=10kΩ pull-up do 3V3 + C=100nF do GND (debounce)\n# Fizyczne połączenie: IDC-20_SWITCH_BUS + Conn_02x06\n#\n# --- Tryby pracy (SW_MODE_Px) ---\n# P1 → AUTO (NORMAL)\n# P2 → ANTI-GRID\n# P3 → BAT-SAVE\n# P4 → BLACKOUT\n# P5 → [rezerwa / przyszłe rozszerzenie]\n#\n# --- Skala czasu (SW_RANGE_Px) ---\n# P1 → LIVE\n# P2 → 1 DAY\n# P3 → 7 DAYS\n# P4 → 14 DAYS\n# P5 → LAST MONTH\n# P6 → 6 MONTHS\n# P7 → 12 MONTHS\n#\n# --- Sekcja ZONE ADM (ZONE_CMDx) ---\n# CMD1 → WAY  (zew. oświetlenie)\n# CMD2 → GARDEN  (strefa ogród)\n# CMD3 → ALARM  (system bezpieczeństwa)\n# CMD4 → OPEN_PLACE  (wolna strefa / rezerwa)\n#\n# Opis działania:\n# Każdy przełącznik zwiera linię do GND → MCP odczytuje stan '0'\n# W stanie nieaktywnym linia trzymana przez pull-up → stan '1'\n# Stany odczytywane przez Raspberry Pi po I²C"
		(exclude_from_sim no)
		(at 34.29 224.028 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
