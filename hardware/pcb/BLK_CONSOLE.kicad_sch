	(text "# BLK_CONSOLE - Opis funkcjonalny\n# ===============================\n# Sekcja: Panel sterowania (tryby MODE + enkodery + ring LED)\n# Układ główny: MCP23017 (U15) @ I²C addr 0x23\n# Napięcie logiki: 3.3V\n# Filtracja wejść: R=10kΩ pull-up do 3V3 + C=100nF do GND (debounce)\n# Fizyczne połączenie: IDC-16_CONSOLE (2x8)\n# Dodatkowe linie: INT_CONSOLED (przerwanie z MCP → opcjonalnie RPi)\n#\n# --- Tryby pracy (MODE_A/B/C) ---\n# MODE_A_SIG → wybór trybu 1\n# MODE_B_SIG → wybór trybu 2\n# MODE_C_SIG → wybór trybu 3\n# Każdy przycisk zwiera do masy. W stanie spoczynku linia = HIGH (pull-up 10k).\n#\n# --- Enkoder głośności (ENC_VOL) ---\n# ENC_VOL_A / ENC_VOL_B → sygnały kwadraturowe z enkodera\n# ENC_VOL_SW → przycisk w osi enkodera (push)\n# VOL_RING_DATA → sygnał sterujący LED-ringiem (z BLK_METER_LED)\n#\n# --- Enkoder górny (ENC_TOP) ---\n# ENC_TOP_A / ENC_TOP_B → sygnały enkodera obrotowego\n# ENC_TOP_SW → przycisk w osi enkodera (push)\n#\n# --- Enkoder dolny (ENC_BOTTOM) ---\n# ENC_BOTTOM_A / ENC_BOTTOM_B → sygnały enkodera obrotowego\n# ENC_BOTTOM_SW → przycisk w osi enkodera (push)\n#\n# --- Rozkład złącza IDC-16_CONSOLE ---\n# 1  → MODE_A_SIG        2 → GND\n# 3  → MODE_B_SIG        4 → ENC_VOL_SW\n# 5  → MODE_C_SIG        6 → GND\n# 7  → VOL_RING_DATA     8 → GND\n# 9  → ENC_VOL_A         10 → ENC_VOL_B\n# 11 → ENC_TOP_A         12 → ENC_TOP_B\n# 13 → ENC_TOP_SW        14 → ENC_BOTTOM_A\n# 15 → ENC_BOTTOM_B      16 → ENC_BOTTOM_SW\n#\n# Opis działania:\n# Wszystkie przyciski i enkodery pracują w logice aktywnego stanu niskiego (GND).\n# MCP23017 generuje przerwanie INT_CONSOLED przy zmianie stanu wejścia (opcjonalne).\n# Stany są odczytywane przez Raspberry Pi po magistrali I²C (3.3V)."
		(exclude_from_sim no)
